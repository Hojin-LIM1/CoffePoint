{
  "family": "coffee-point-task",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "512",
  "memory": "1024",
  "executionRoleArn": "arn:aws:iam::ACCOUNT_ID:role/ecsTaskExecutionRole",
  "taskRoleArn": "arn:aws:iam::ACCOUNT_ID:role/ecsTaskRole",
  "containerDefinitions": [
    {
      "name": "coffee-point",
      "image": "ACCOUNT_ID.dkr.ecr.ap-northeast-2.amazonaws.com/coffee-point:latest",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 8080,
          "protocol": "tcp"
        }
      ],
      "environment": [
        { "name": "SPRING_PROFILES_ACTIVE", "value": "prod" },
        { "name": "SERVER_PORT", "value": "8080" },
        { "name": "TZ", "value": "Asia/Seoul" }
      ],
      "secrets": [
        {
          "name": "SPRING_DATASOURCE_URL",
          "valueFrom": "arn:aws:ssm:ap-northeast-2:ACCOUNT_ID:parameter/coffee-point/prod/db-url"
        },
        {
          "name": "SPRING_DATASOURCE_USERNAME",
          "valueFrom": "arn:aws:ssm:ap-northeast-2:ACCOUNT_ID:parameter/coffee-point/prod/db-username"
        },
        {
          "name": "SPRING_DATASOURCE_PASSWORD",
          "valueFrom": "arn:aws:ssm:ap-northeast-2:ACCOUNT_ID:parameter/coffee-point/prod/db-password"
        },
        {
          "name": "SPRING_DATA_REDIS_HOST",
          "valueFrom": "arn:aws:ssm:ap-northeast-2:ACCOUNT_ID:parameter/coffee-point/prod/redis-host"
        },
        {
          "name": "SPRING_KAFKA_BOOTSTRAP_SERVERS",
          "valueFrom": "arn:aws:ssm:ap-northeast-2:ACCOUNT_ID:parameter/coffee-point/prod/kafka-brokers"
        }
      ],
      "healthCheck": {
        "command": ["CMD-SHELL", "wget -qO- http://localhost:8080/actuator/health || exit 1"],
        "interval": 30,
        "timeout": 5,
        "retries": 3,
        "startPeriod": 60
      },
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/coffee-point",
          "awslogs-region": "ap-northeast-2",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ]
}
